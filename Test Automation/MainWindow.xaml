                                                    Visibility="{Binding IsHttpSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBox Text="{Binding HttpRequestCookiesPreview}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       AcceptsReturn="True"
                                                       VerticalScrollBarVisibility="Auto"
                                                       HorizontalScrollBarVisibility="Auto"
                                                       IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Req Metadata"
                                                    Visibility="{Binding IsHttpSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBox Text="{Binding HttpRequestMetadataPreview}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       AcceptsReturn="True"
                                                       VerticalScrollBarVisibility="Auto"
                                                       HorizontalScrollBarVisibility="Auto"
                                                       IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Res Headers"
                                                     Visibility="{Binding IsHttpSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBox Text="{Binding HttpResponseHeadersPreview}"
                                                         FontFamily="Consolas"
                                                         FontSize="12"
                                                         AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Res Cookies"
                                                    Visibility="{Binding IsHttpSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBox Text="{Binding HttpResponseCookiesPreview}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       AcceptsReturn="True"
                                                       VerticalScrollBarVisibility="Auto"
                                                       HorizontalScrollBarVisibility="Auto"
                                                       IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Res Metadata"
                                                    Visibility="{Binding IsHttpSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBox Text="{Binding HttpResponseMetadataPreview}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       AcceptsReturn="True"
                                                       VerticalScrollBarVisibility="Auto"
                                                       HorizontalScrollBarVisibility="Auto"
                                                       IsReadOnly="True" />
                                            </TabItem>
                                        </TabControl>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                    </Border>

                            </Grid>

                            <StackPanel Grid.Row="2" Visibility="Collapsed">

                    <TextBlock Text="Settings" FontWeight="SemiBold" Margin="0,8,0,8" Visibility="Collapsed" />

                    <ScrollViewer MinHeight="140" VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch" Visibility="Collapsed">
                        <ItemsControl ItemsSource="{Binding SelectedNode.Settings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Margin="0,0,6,0" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="#666666">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource VariableSettingUsageLabelConverter}">
                                                    <Binding Path="Key" />
                                                    <Binding Path="Value" />
                                                    <Binding Path="DataContext.VariableUsageVersion" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                            <TextBlock.ToolTip>
                                                <MultiBinding Converter="{StaticResource VariableSettingUsageTooltipConverter}">
                                                    <Binding Path="Key" />
                                                    <Binding Path="Value" />
                                                    <Binding Path="DataContext.VariableUsageVersion" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                        <Button Grid.Column="3" Content="X" Width="26" Height="24" Click="RemoveSettingButton_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                        <Button Content="Add Setting" Width="100" Click="AddSettingButton_Click" />
                    </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="1"
                          Height="6"
                          Margin="0,10,0,10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="#E0E0E0"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Row="2" MinHeight="80" BorderBrush="#D8D8D8" BorderThickness="1" Padding="12" CornerRadius="4" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="Global Preview Panel" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="Preview tabs are now available directly inside Project and Component editor tabs." Foreground="#555555" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
