                                <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding DatasetCsvDelimiter, UpdateSourceTrigger=PropertyChanged}" ToolTip="Delimiter, e.g. , or ; or |" />
                                <CheckBox Grid.Column="2" VerticalAlignment="Center" Content="Has Header"
                                          IsChecked="{Binding DatasetCsvHasHeader, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="JSON Path" />
                                <TextBox Grid.Column="1" Text="{Binding DatasetJsonArrayPath, UpdateSourceTrigger=PropertyChanged}" ToolTip="Optional path to array, e.g. data.items" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="XML Row Path" />
                                <TextBox Grid.Column="1" Text="{Binding DatasetXmlRowPath, UpdateSourceTrigger=PropertyChanged}" ToolTip="Optional row path, e.g. root/items/item" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Max Rows" />
                                <TextBox Grid.Column="1" Margin="0,0,8,0" Text="{Binding DatasetMaxRows, UpdateSourceTrigger=PropertyChanged}" ToolTip="0 means all rows" />
                                <Button Grid.Column="2" Content="Refresh Preview" Width="110" Click="RefreshDatasetPreviewButton_Click" />
                            </Grid>
                            <TextBlock Margin="0,0,0,6" Foreground="#4F5D6B" Text="{Binding DatasetPreviewStatus}" TextWrapping="Wrap" />
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="4">
                                <DataGrid ItemsSource="{Binding DatasetPreviewRows}"
                                          AutoGenerateColumns="True"
                                          AutoGeneratingColumn="DatasetPreviewGrid_AutoGeneratingColumn"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="All"
                                          MinHeight="180"
                                          MaxHeight="300"
                                          GridLinesVisibility="All" />
                            </Border>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsTimerSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid Background="{DynamicResource WindowBackgroundBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Delay (ms)" />
                            <TextBox Grid.Column="1" Text="{Binding TimerDelayMs, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsLoopSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Iterations" />
                                <TextBox Grid.Column="1" Text="{Binding LoopIterations, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            
                            <!-- View Assertions Button for Loop -->
                            <Button Content="📊 View Assertions" 
                                    Height="32"
                                    Click="ViewAssertionsButton_Click"
                                    ToolTip="View assertion history for all child components"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsForeachSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Source Variable" />
                                <TextBox Grid.Column="1" Text="{Binding ForeachSourceVariable, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Variable name holding a collection (array, JSON array, or comma-separated string). Each iteration exposes CurrentItem and CurrentIndex." />
                            </Grid>
                            <Grid Background="{DynamicResource WindowBackgroundBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Output Variable" />
                                <TextBox Grid.Column="1" Text="{Binding ForeachOutputVariable, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Optional variable name that stores the current item for use by child components (defaults to CurrentItem)." />
                            </Grid>
                            
                            <!-- View Assertions Button for Foreach -->
                            <Button Content="📊 View Assertions" 
                                    Height="32" Margin="0,8,0,0"
                                    Click="ViewAssertionsButton_Click"
                                    ToolTip="View assertion history for all child components"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsIfSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Condition" />
                                <TextBox Grid.Column="1" Text="{Binding IfCondition, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            
                            <!-- View Assertions Button for If -->
                            <Button Content="📊 View Assertions" 
                                    Height="32"
                                    Click="ViewAssertionsButton_Click"
                                    ToolTip="View assertion history for all child components"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsThreadsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Threads" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Count" />
                                <TextBox Grid.Column="1" Text="{Binding ThreadCount, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Background="{DynamicResource WindowBackgroundBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="RampUp (s)" />
                                <TextBox Grid.Column="1" Text="{Binding RampUpSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            
                            <!-- View Assertions Button for Threads -->
                            <Button Content="📊 View Assertions" 
                                    Height="32" Margin="0,8,0,0"
                                    Click="ViewAssertionsButton_Click"
                                    ToolTip="View assertion history for all child components"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsAssertSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Assert" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Expected" />
                                <TextBox Grid.Column="1" Text="{Binding AssertExpected, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Background="{DynamicResource WindowBackgroundBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Actual" />
                                <TextBox Grid.Column="1" Text="{Binding AssertActual, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsVariableExtractorSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Variable Extractor" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Pattern" />
                                <TextBox Grid.Column="1" Text="{Binding ExtractorPattern, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Background="{DynamicResource WindowBackgroundBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Variable" />
                                <ComboBox Grid.Column="1" 
                                          ItemsSource="{Binding AvailableVariablesForExtractor}"
                                          SelectedItem="{Binding ExtractorVariableName, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          Margin="0,0,6,0" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource VariableUsageLabelConverter}">
                                            <Binding Path="ExtractorVariableName" />
                                            <Binding Path="VariableUsageVersion" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                    <TextBlock.ToolTip>
                                        <MultiBinding Converter="{StaticResource VariableUsageTooltipConverter}">
                                            <Binding Path="ExtractorVariableName" />
                                            <Binding Path="VariableUsageVersion" />
                                        </MultiBinding>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsScriptSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Script" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Language" />
                                <TextBox Grid.Column="1" Text="{Binding ScriptLanguage, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Background="{DynamicResource WindowBackgroundBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Top" Text="Code" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding ScriptCode, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         Height="80"
                                         VerticalScrollBarVisibility="Auto"
                                         IsReadOnly="True"
                                         Cursor="Hand"
                                         ToolTip="Click to open script editor"
                                         PreviewMouseLeftButtonDown="ScriptCodeTextBox_PreviewMouseLeftButtonDown" />
                            </Grid>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsRandomGeneratorSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Random Generator" FontWeight="SemiBold" Margin="0,0,0,6" />
                            
                            <!-- Output Type -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Output Type" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding RandomOutputTypeOptions}"
                                          SelectedItem="{Binding RandomOutputType, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="Type of random value to generate" />
                            </Grid>
                            
                            <!-- Min -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Min" />
                                <TextBox Grid.Column="1" Text="{Binding RandomMin, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Minimum value for number generation" />
                            </Grid>
                            
                            <!-- Max -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Max" />
                                <TextBox Grid.Column="1" Text="{Binding RandomMax, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Maximum value for number generation" />
                            </Grid>
                            
                            <!-- Length -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Length" />
                                <TextBox Grid.Column="1" Text="{Binding RandomLength, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Length for string/UUID generation" />
                            </Grid>
                            
                            <!-- Decimal Places -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Decimals" />
                                <TextBox Grid.Column="1" Text="{Binding RandomDecimalPlaces, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Number of decimal places for float/double" />
                            </Grid>
                            
                            <!-- Include Options (for strings) -->
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="6" CornerRadius="3" Margin="0,0,0,6"
                                    Visibility="{Binding RandomShowStringOptions, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Character Sets" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <CheckBox Content="Uppercase (A-Z)" IsChecked="{Binding RandomIncludeUpper}" Margin="0,0,0,2" />
                                    <CheckBox Content="Lowercase (a-z)" IsChecked="{Binding RandomIncludeLower}" Margin="0,0,0,2" />
                                    <CheckBox Content="Numbers (0-9)" IsChecked="{Binding RandomIncludeNumbers}" Margin="0,0,0,2" />
                                    <CheckBox Content="Special Characters" IsChecked="{Binding RandomIncludeSpecial}" Margin="0,0,0,2" />
                                </StackPanel>
                            </Border>
                            
                            <!-- Array Settings -->
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="6" CornerRadius="3" Margin="0,0,0,6"
                                    Visibility="{Binding RandomShowArrayOptions, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Array Settings" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Array Length" />
                                        <TextBox Grid.Column="1" Text="{Binding RandomArrayLength, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Item Type" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding RandomItemTypeOptions}"
                                                  SelectedItem="{Binding RandomItemType, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                            
                            <!-- JSON Structure Builder -->
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="6" CornerRadius="3" Margin="0,0,0,6"
                                    Visibility="{Binding RandomShowJsonOptions, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="JSON Structure Builder" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="Define keys and types. Add nested objects or arrays for complex structures." 
                                               Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,6" />
                                    
                                    <!-- Action Buttons -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Content="+ Add Key" Click="AddJsonKey_Click" Padding="8,4" Margin="0,0,4,0" />
                                        <Button Content="+ Add Object" Click="AddJsonObject_Click" Padding="8,4" Margin="0,0,4,0" />
                                        <Button Content="+ Add Array" Click="AddJsonArray_Click" Padding="8,4" Margin="0,0,4,0" />
                                        <Button Content="Clear All" Click="ClearJsonStructure_Click" Padding="8,4" />
                                    </StackPanel>
                                    
                                    <!-- JSON Tree View -->
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" MaxHeight="300">
                                        <TreeView ItemsSource="{Binding JsonStructureNodes}" 
                                                  Background="{DynamicResource WindowBackgroundBrush}">
                                            <TreeView.ItemTemplate>
                                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                    <StackPanel Orientation="Vertical" Margin="0,2">
                                                        <!-- Main Row -->
                                                        <StackPanel Orientation="Horizontal">
                                                            <!-- Indent based on nesting level -->
                                                            <Border Width="{Binding NestingLevel, Converter={StaticResource NestingToWidthConverter}}" />
                                                            
                                                            <!-- Expand/Collapse Button -->
                                                            <Button Content="{Binding IsExpanded, Converter={StaticResource BoolToExpandConverter}}"
                                                                    Width="20" Height="20" Padding="0"
                                                                    Visibility="{Binding ValueType, Converter={StaticResource HasChildrenConverter}}"
                                                                    Click="ToggleExpand_Click"
                                                                    Tag="{Binding}" />
                                                            
                                                            <!-- Key Name -->
                                                            <TextBox Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" 
                                                                     Width="120" Height="22" Padding="2"
                                                                     ToolTip="Property name" />
                                                            
                                                            <TextBlock Text=":" VerticalAlignment="Center" Margin="4,0" />
                                                            
                                                            <!-- Value Type -->
                                                                <ComboBox ItemsSource="{Binding Source={x:Static editor:JsonStructureNode.ValueTypes}}"
                                                                      SelectedItem="{Binding ValueType, UpdateSourceTrigger=PropertyChanged}"
                                                                      Width="100" Height="22"
                                                                      ToolTip="Value type" />
                                                            
                                                            <!-- Array Settings (visible for arrays) -->
                                                            <StackPanel Orientation="Horizontal" Visibility="{Binding ShowArraySettings, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <TextBlock Text="Length:" VerticalAlignment="Center" Margin="8,0,2,0" />
                                                                <TextBox Text="{Binding ArrayLength, UpdateSourceTrigger=PropertyChanged}" 
                                                                         Width="40" Height="22" Padding="2" />
                                                                
                                                                <TextBlock Text="Items:" VerticalAlignment="Center" Margin="8,0,2,0" />
                                                                <ComboBox ItemsSource="{Binding Source={x:Static editor:JsonStructureNode.ArrayItemTypes}}"
                                                                          SelectedItem="{Binding ItemType, UpdateSourceTrigger=PropertyChanged}"
                                                                          Width="80" Height="22" />
                                                            </StackPanel>
                                                            
                                                            <!-- Action Buttons -->
                                                            <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                                                                <Button Content="+" Width="22" Height="22" Padding="0" Margin="0,0,2,0"
                                                                        Click="AddChildKey_Click" Tag="{Binding}"
                                                                        ToolTip="Add child key" />
                                                                <Button Content="{}{ }" Width="22" Height="22" Padding="0" Margin="0,0,2,0"
                                                                        Click="AddNestedObject_Click" Tag="{Binding}"
                                                                        Visibility="{Binding ShowObjectChildren, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                        ToolTip="Add nested object" />
                                                                <Button Content="[ ]" Width="22" Height="22" Padding="0" Margin="0,0,2,0"
                                                                        Click="AddNestedArray_Click" Tag="{Binding}"
                                                                        Visibility="{Binding ShowObjectChildren, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                        ToolTip="Add nested array" />
                                                                <Button Content="X" Width="22" Height="22" Padding="0"
                                                                        Click="RemoveJsonNode_Click" Tag="{Binding}"
                                                                        ToolTip="Remove" Foreground="Red" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        
                                                        <!-- Array Item Children (for arrays with object items) -->
                                                        <StackPanel Visibility="{Binding ShowArrayItemObjectChildren, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                    Margin="20,4,0,0">
                                                            <TextBlock Text="Array Item Properties:" FontWeight="SemiBold" Margin="0,0,0,4" 
                                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                                            <ItemsControl ItemsSource="{Binding ArrayItemChildren}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                            <TextBlock Text="  ► " VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                                                                            <TextBox Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" 
                                                                                     Width="100" Height="22" Padding="2" />
                                                                            <TextBlock Text=":" VerticalAlignment="Center" Margin="4,0" />
                                                                            <ComboBox ItemsSource="{Binding Source={x:Static editor:JsonStructureNode.ValueTypes}}"
                                                                                      SelectedItem="{Binding ValueType, UpdateSourceTrigger=PropertyChanged}"
                                                                                      Width="90" Height="22" />
                                                                            <Button Content="X" Width="22" Height="22" Padding="0" Margin="4,0,0,0"
                                                                                    Click="RemoveArrayItem_Click" Tag="{Binding}"
                                                                                    ToolTip="Remove" Foreground="Red" />
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <Button Content="+ Add Array Item Key" Click="AddArrayItemKey_Click" Tag="{Binding}"
                                                                    Padding="8,2" Margin="0,4,0,0" HorizontalAlignment="Left"
                                                                    ToolTip="Add a property to array items" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </HierarchicalDataTemplate>
                                            </TreeView.ItemTemplate>
                                        </TreeView>
                                    </Border>
                                    
                                    <!-- Preview -->
                                    <Expander Header="Preview JSON" Margin="0,6,0,0" IsExpanded="False">
                                        <TextBox Text="{Binding RandomJsonStructure, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 Height="80"
                                                 VerticalScrollBarVisibility="Auto"
                                                 TextWrapping="Wrap"
                                                 FontFamily="Consolas" />
                                    </Expander>
                                </StackPanel>
                            </Border>
                            
                            <!-- Email Domain -->
                            <Grid Margin="0,0,0,6"
                                  Visibility="{Binding RandomShowEmailOption, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Email Domain" />
                                <TextBox Grid.Column="1" Text="{Binding RandomEmailDomain, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Custom email domain (optional, e.g., company.com)" />
                            </Grid>
                            
                            <!-- Variable Name -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Variable Name" />
                                <TextBox Grid.Column="1" Text="{Binding RandomVariableName, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Optional: Store result in this variable" />
                            </Grid>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsTestPlanSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="TestPlan" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Execution Type" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding ExecutionTypeOptions}"
                                          SelectedItem="{Binding SelectedExecutionType, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Thread Count" />
                                <TextBox Grid.Column="1" Text="{Binding TestPlanThreadCount, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <TextBlock Text="Set Thread Count > 1 to run children in parallel" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" Margin="0,0,0,6" />
                            <TextBlock Text="PreExecute runs first, PostExecute runs last" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" Margin="0,0,0,6" />
                            
                            <!-- View Assertions Button for TestPlan -->
                            <Button Content="📊 View Assertions" 
                                    Height="32" Margin="0,8,0,0"
                                    Click="ViewAssertionsButton_Click"
                                    ToolTip="View assertion history for all child components"
                                    HorizontalAlignment="Stretch"/>
                            
                            <TextBlock Text="Local Variables" FontWeight="SemiBold" Margin="0,10,0,6" />
                            <ScrollViewer MinHeight="80" VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch">
                                <ItemsControl ItemsSource="{Binding TestPlanVariablesForEditor}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Margin="0,0,6,0" Text="{Binding Key, UpdateSourceTrigger=LostFocus}" />
                                                <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding Value, UpdateSourceTrigger=LostFocus}" />
                                                <Button Grid.Column="2" Content="X" Width="26" Height="24" Click="RemoveTestPlanVariableButton_Click" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <Button Content="Add Variable" Width="100" Margin="0,6,0,0" Click="AddTestPlanVariableButton_Click" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem Header="Assign Value to Variable">
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Assign Value to Variable" FontWeight="SemiBold" Margin="0,0,0,6" />

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Source Field" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="JSON Path" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="3" Text="Variable Name" FontWeight="SemiBold" />
                            </Grid>

                            <ScrollViewer MinHeight="120" VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch">
                                <ItemsControl ItemsSource="{Binding SelectedNode.Extractors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0"
                                                          Margin="0,0,6,0"
                                                          ItemsSource="{Binding DataContext.ExtractorSourceOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          Text="{Binding Source, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding JsonPath, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Grid.Column="2"
                                                        Margin="0,0,6,0"
                                                        Width="32"
                                                        Height="24"
                                                        Content="..."
                                                        ToolTip="Explore JSON paths"
                                                        Click="ExploreJsonPathButton_Click" />
                                                <Grid Grid.Column="3" Margin="0,0,6,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox Grid.Column="0"
                                                          Margin="0,0,6,0"
                                                          ItemsSource="{Binding DataContext.AvailableVariablesForExtractor, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          Text="{Binding VariableName, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource VariableUsageLabelConverter}">
                                                                <Binding Path="VariableName" />
                                                                <Binding Path="DataContext.VariableUsageVersion" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                        <TextBlock.ToolTip>
                                                            <MultiBinding Converter="{StaticResource VariableUsageTooltipConverter}">
                                                                <Binding Path="VariableName" />
                                                                <Binding Path="DataContext.VariableUsageVersion" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                            </MultiBinding>
                                                        </TextBlock.ToolTip>
                                                    </TextBlock>
                                                </Grid>
                                                <Button Grid.Column="4" Content="X" Width="26" Height="24" Click="RemoveExtractorButton_Click" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="Add Extractor" Width="120" Click="AddExtractorButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                                </TabItem>

                            <TabItem Header="Assertions">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Assertions" FontWeight="SemiBold" Margin="0,0,0,6" />

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Mode" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="JSON Path" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="3" Text="Condition" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="4" Text="Expected" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="5" Text="Status" FontWeight="SemiBold" />
                            </Grid>

                            <Grid MinHeight="260" Margin="0,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition x:Name="AssertionRowsAreaRow" Height="120" MinHeight="70" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition x:Name="AssertionTreeAreaRow" Height="*" MinHeight="120" />
                                </Grid.RowDefinitions>

                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SelectedNode.Assertions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="90" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox Grid.Column="0"
                                                              Margin="0,0,6,0"
                                                              ItemsSource="{Binding DataContext.AssertionModeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedItem="{Binding Mode, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding JsonPath, UpdateSourceTrigger=PropertyChanged}" />
                                                    <ComboBox Grid.Column="3"
                                                              Margin="0,0,6,0"
                                                              ItemsSource="{Binding DataContext.AssertionConditionOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedItem="{Binding Condition, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBox Grid.Column="4"
                                                             Margin="0,0,6,0"
                                                             Text="{Binding Expected, UpdateSourceTrigger=PropertyChanged}"
                                                             PreviewMouseLeftButtonDown="AssertionExpectedTextBox_PreviewMouseLeftButtonDown">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="AcceptsReturn" Value="False" />
                                                                <Setter Property="TextWrapping" Value="NoWrap" />
                                                                <Setter Property="Height" Value="24" />
                                                                <Setter Property="MinHeight" Value="24" />
                                                                <Setter Property="MaxHeight" Value="24" />
                                                                <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
                                                                <Setter Property="HorizontalScrollBarVisibility" Value="Hidden" />
                                                                <Setter Property="IsReadOnly" Value="True" />
                                                                <Setter Property="Cursor" Value="Hand" />
                                                                <Setter Property="ToolTip" Value="Click to open expected value editor" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Condition}" Value="Script">
                                                                        <Setter Property="ToolTip" Value="Click to open script editor" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                    <Border Grid.Column="5" Margin="0,0,6,0" CornerRadius="3" Padding="6,2" BorderBrush="#D1D5DB" BorderThickness="1">
                                                        <TextBlock Text="{Binding StatusLabel}" ToolTip="{Binding StatusMessage}" HorizontalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding LastResultState}" Value="Passed">
                                                                            <Setter Property="Foreground" Value="#166534" />
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding LastResultState}" Value="AssertFailed">
                                                                            <Setter Property="Foreground" Value="#B00020" />
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding LastResultState}" Value="ExpectFailed">
                                                                            <Setter Property="Foreground" Value="#A16207" />
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <Button Grid.Column="7" Content="X" Width="26" Height="24" Click="RemoveAssertionButton_Click" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <GridSplitter Grid.Row="1"
                                              Height="6"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              Background="{DynamicResource BorderBrush}"
                                              ResizeDirection="Rows"
                                              ResizeBehavior="PreviousAndNext"
                                              ShowsPreview="True" />

                                <Border Grid.Row="2" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,8,0,0">
                                <Grid Background="{DynamicResource WindowBackgroundBrush}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" MinHeight="80" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="AssertionTreeLeftColumn" Width="2*" MinWidth="160" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition x:Name="AssertionTreeRightColumn" Width="3*" MinWidth="220" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="Assertion Tree" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <TextBlock Text="Source" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock x:Name="AssertionTreeSourceLabel"
                                                   Text="PreviewVariables"
                                                   VerticalAlignment="Center"
                                                   Width="180"
                                                   Margin="0,0,6,0" />
                                        <Button Width="70" Content="Refresh" Click="RefreshAssertionTreeButton_Click" />
                                    </StackPanel>

                                    <TreeView x:Name="AssertionJsonTreeView"
                                              Grid.Row="1"
                                              Grid.Column="0"
                                              Margin="0,0,8,0"
                                              SelectedItemChanged="AssertionJsonTreeView_SelectedItemChanged">
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                    </TreeView>

                                     <GridSplitter Grid.Row="1"
                                                Grid.Column="1"
                                                Width="6"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                Background="{DynamicResource BorderBrush}"
                                                ResizeDirection="Columns"
                                                ResizeBehavior="PreviousAndNext"
                                                ShowsPreview="True" />

                                    <TextBox x:Name="AssertionTreeValuePreviewTextBox"
                                             Grid.Row="1"
                                            Grid.Column="2"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             Text="Select a tree node to preview value." />

                                    <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AssertionTreeSelectedPathTextBlock"
                                                   Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"
                                                   Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="Path: (none)" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Width="130"
                                                    Margin="0,0,6,0"
                                                    Content="Add Selected Row"
                                                    Click="AddSelectedTreeNodeAssertionButton_Click" />
                                            <Button Width="190"
                                                    Content="Generate Rows For Tree"
                                                    Click="GenerateTreeAssertionsButton_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>
                        </ScrollViewer>
                                </TabItem>

                                <TabItem Header="Preview">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock VerticalAlignment="Center" Text="Preview Data" Margin="0,0,8,0" />
                                            <ComboBox Width="140"
                                                      ItemsSource="{Binding PreviewDataModeOptions}"
                                                      SelectedItem="{Binding SelectedPreviewDataMode, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <TabControl Grid.Row="1" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                                            <TabItem Header="Request">
                                                <TextBox Text="{Binding PreviewRequest}"
                                                         FontFamily="Consolas"
                                                         FontSize="12"
                                                         AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Response">
                                                <TextBox Text="{Binding PreviewResponse}"
                                                         FontFamily="Consolas"
                                                         FontSize="12"
                                                         AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Output">
                                                <TextBox Text="{Binding PreviewOutput}"
                                                         FontFamily="Consolas"
                                                         FontSize="12"
                                                         AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Logs">
                                                <TextBox Text="{Binding PreviewLogs}"
                                                         FontFamily="Consolas"
                                                         FontSize="12"
                                                         AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Variables">
                                                <TextBox Text="{Binding VariablesPreview}"
                                                         FontFamily="Consolas"
                                                         FontSize="12"
                                                         AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Assertions">
                                                <TextBox Text="{Binding AssertionPreview}"
                                                         FontFamily="Consolas"
                                                         FontSize="12"
                                                         AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Req Headers"
                                                     Visibility="{Binding IsHttpSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBox Text="{Binding HttpRequestHeadersPreview}"
                                                         FontFamily="Consolas"
                                                         FontSize="12"
                                                         AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Req Cookies"
                                                    Visibility="{Binding IsHttpSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBox Text="{Binding HttpRequestCookiesPreview}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       AcceptsReturn="True"
                                                       VerticalScrollBarVisibility="Auto"
                                                       HorizontalScrollBarVisibility="Auto"
                                                       IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Req Metadata"
                                                    Visibility="{Binding IsHttpSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBox Text="{Binding HttpRequestMetadataPreview}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       AcceptsReturn="True"
                                                       VerticalScrollBarVisibility="Auto"
                                                       HorizontalScrollBarVisibility="Auto"
                                                       IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Res Headers"
                                                     Visibility="{Binding IsHttpSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBox Text="{Binding HttpResponseHeadersPreview}"
                                                         FontFamily="Consolas"
                                                         FontSize="12"
                                                         AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Res Cookies"
                                                    Visibility="{Binding IsHttpSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBox Text="{Binding HttpResponseCookiesPreview}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       AcceptsReturn="True"
                                                       VerticalScrollBarVisibility="Auto"
                                                       HorizontalScrollBarVisibility="Auto"
                                                       IsReadOnly="True" />
                                            </TabItem>
                                            <TabItem Header="Res Metadata"
                                                    Visibility="{Binding IsHttpSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBox Text="{Binding HttpResponseMetadataPreview}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       AcceptsReturn="True"
                                                       VerticalScrollBarVisibility="Auto"
                                                       HorizontalScrollBarVisibility="Auto"
                                                       IsReadOnly="True" />
                                            </TabItem>
                                        </TabControl>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                    </Border>

                            </Grid>

                            <StackPanel Grid.Row="2" Visibility="Collapsed">

                    <TextBlock Text="Settings" FontWeight="SemiBold" Margin="0,8,0,8" Visibility="Collapsed" />

                    <ScrollViewer MinHeight="140" VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch" Visibility="Collapsed">
                        <ItemsControl ItemsSource="{Binding SelectedNode.Settings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Margin="0,0,6,0" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource VariableSettingUsageLabelConverter}">
                                                    <Binding Path="Key" />
                                                    <Binding Path="Value" />
                                                    <Binding Path="DataContext.VariableUsageVersion" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                            <TextBlock.ToolTip>
                                                <MultiBinding Converter="{StaticResource VariableSettingUsageTooltipConverter}">
                                                    <Binding Path="Key" />
                                                    <Binding Path="Value" />
                                                    <Binding Path="DataContext.VariableUsageVersion" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                        <Button Grid.Column="3" Content="X" Width="26" Height="24" Click="RemoveSettingButton_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                        <Button Content="Add Setting" Width="100" Click="AddSettingButton_Click" />
                    </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="1"
                          Height="6"
                          Margin="0,10,0,10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="{DynamicResource BorderBrush}"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Row="2" MinHeight="80" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12" CornerRadius="4" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="Global Preview Panel" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="Preview tabs are now available directly inside Project and Component editor tabs." Foreground="#555555" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>



