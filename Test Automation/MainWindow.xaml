<Window x:Class="Test_Automation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test_Automation"
        xmlns:conv="clr-namespace:Test_Automation.Converters"
        mc:Ignorable="d"
        Title="Test Automation" Height="650" Width="1100">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:VariableUsageLabelConverter x:Key="VariableUsageLabelConverter" />
        <conv:VariableUsageTooltipConverter x:Key="VariableUsageTooltipConverter" />
        <conv:VariableSettingUsageLabelConverter x:Key="VariableSettingUsageLabelConverter" />
        <conv:VariableSettingUsageTooltipConverter x:Key="VariableSettingUsageTooltipConverter" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="MainLeftColumn" Width="320" MinWidth="220" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="MainRightColumn" Width="*" MinWidth="420" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#D0D0D0" BorderThickness="0,0,1,0" Background="#FAFAFA">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="LeftTopControlsRow" Height="Auto" MinHeight="140" />
                    <RowDefinition Height="6" />
                    <RowDefinition x:Name="LeftTreeRow" Height="*" MinHeight="120" />
                </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="AddProjectButton"
                    Height="32"
                    Width="100"
                    Margin="0,0,8,0"
                    Content="Add Project"
                    Click="AddProjectButton_Click" />
                <Button x:Name="SaveProjectButton"
                    Height="32"
                    Width="70"
                    Margin="0,0,8,0"
                    Content="Save"
                    Click="SaveProjectButton_Click" />
                <Button x:Name="SaveProjectAsButton"
                    Height="32"
                    Width="80"
                    Margin="0,0,8,0"
                    Content="Save As"
                    Click="SaveProjectAsButton_Click" />
                <Button x:Name="LoadProjectButton"
                    Height="32"
                    Width="90"
                    Content="Load JSON"
                    Click="LoadProjectButton_Click" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="RunTestPlanButton"
                    Height="32"
                    Width="120"
                    Content="Run TestPlan"
                    Click="RunTestPlanButton_Click" />
                <Button x:Name="StopRunButton"
                    Height="32"
                    Width="90"
                    Margin="8,0,0,0"
                    Content="Stop"
                    IsEnabled="False"
                    Click="StopRunButton_Click" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock VerticalAlignment="Center" Text="Environment" Margin="0,0,8,0" />
                <ComboBox Width="170"
                          ItemsSource="{Binding EnvironmentOptions}"
                          SelectedItem="{Binding SelectedEnvironment, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock VerticalAlignment="Center" Text="Trace Level" Margin="0,0,8,0" />
                <ComboBox Width="170"
                          ItemsSource="{Binding TraceLevelOptions}"
                          SelectedItem="{Binding SelectedTraceLevel, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            </StackPanel>

                <GridSplitter Grid.Row="1"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="#E0E0E0"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              ShowsPreview="True" />

                <TreeView Grid.Row="2"
                          x:Name="PlanTreeView"
                          ItemsSource="{Binding RootNodes}"
                          AllowDrop="True"
                          SelectedItemChanged="PlanTreeView_SelectedItemChanged"
                          PreviewMouseLeftButtonDown="PlanTreeView_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="PlanTreeView_PreviewMouseMove"
                          PreviewMouseRightButtonDown="PlanTreeView_PreviewMouseRightButtonDown"
                          DragOver="PlanTreeView_DragOver"
                          Drop="PlanTreeView_Drop">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="AllowDrop" Value="True" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <EventSetter Event="DragEnter" Handler="TreeViewItem_DragEnter" />
                            <EventSetter Event="DragLeave" Handler="TreeViewItem_DragLeave" />
                            <EventSetter Event="DragOver" Handler="TreeViewItem_DragOver" />
                            <EventSetter Event="Drop" Handler="TreeViewItem_Drop" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                    <Setter Property="Background" Value="#FFFFC107" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DisplayName}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#202020" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AssertionSeverity}" Value="AssertFailed">
                                                    <Setter Property="Foreground" Value="#B00020" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AssertionSeverity}" Value="ExpectFailed">
                                                    <Setter Property="Foreground" Value="#A16207" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AssertionSeverity}" Value="Passed">
                                                    <Setter Property="Foreground" Value="#166534" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Margin="8,0,0,0"
                                           Text="{Binding AssertionSummaryLabel}"
                                           Visibility="{Binding HasAssertionSummary, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#6B7280" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AssertionSeverity}" Value="AssertFailed">
                                                    <Setter Property="Foreground" Value="#B00020" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AssertionSeverity}" Value="ExpectFailed">
                                                    <Setter Property="Foreground" Value="#A16207" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AssertionSeverity}" Value="Passed">
                                                    <Setter Property="Foreground" Value="#166534" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                  Width="6"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Background="#E0E0E0"
                  ResizeDirection="Columns"
                  ResizeBehavior="PreviousAndNext"
                  ShowsPreview="True" />

        <Grid x:Name="MainContentGrid" Grid.Column="2" Background="#FFFFFF" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="EditorTopRow" Height="2*" MinHeight="280" />
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="EditorBottomRow" Height="*" MinHeight="80" />
            </Grid.RowDefinitions>

            <Border BorderBrush="#D8D8D8" BorderThickness="1" Padding="12" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="220" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Node Editor" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Type" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedNode.Type, TargetNullValue=Select a node}" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Id" />
                        <TextBox Grid.Column="1" Text="{Binding SelectedNode.Id, Mode=OneWay}" IsReadOnly="True" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Name" />
                        <TextBox Grid.Column="1" Text="{Binding SelectedNode.Name, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Enabled" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding SelectedNode.IsEnabled}" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Clear Children Preview"
                                Width="180"
                                Click="ClearChildrenPreviewButton_Click"
                                Visibility="{Binding HasSelectedNodeChildren, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>

                        </StackPanel>

                        <Grid Grid.Row="1">

                    <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            VerticalAlignment="Stretch"
                            Visibility="{Binding IsProjectSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TabControl HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                            <TabItem Header="Properties">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" MinHeight="120" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="Project" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <ComboBox x:Name="ProjectRunModeComboBox"
                                                      Width="110"
                                                      Margin="10,0,6,0"
                                                      ItemsSource="{Binding ProjectRunModeOptions}"
                                                      SelectedItem="{Binding SelectedProjectRunMode, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button x:Name="RunProjectTestPlansButton"
                                                    Width="130"
                                                    Content="Run TestPlans"
                                                    Click="RunProjectTestPlansButton_Click" />
                                        </StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Description" />
                                            <TextBox Grid.Column="1" Text="{Binding ProjectDescription, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Environment" />
                                            <TextBox Grid.Column="1" Text="{Binding ProjectEnvironment, UpdateSourceTrigger=PropertyChanged}" ToolTip="Use comma, semicolon, or new line to define dropdown options." />
                                        </Grid>
                                        <TextBlock Text="Variables" FontWeight="SemiBold" Margin="0,10,0,6" />
                                    </StackPanel>

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch">
                                        <ItemsControl ItemsSource="{Binding ProjectVariablesForEditor}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Margin="0,0,6,0" Text="{Binding Key, UpdateSourceTrigger=LostFocus}" />
                                                        <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding Value, UpdateSourceTrigger=LostFocus}" />
                                                        <TextBlock Grid.Column="2" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="#666666">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource VariableUsageLabelConverter}">
                                                                    <Binding Path="Key" />
                                                                    <Binding Path="DataContext.VariableUsageVersion" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                            <TextBlock.ToolTip>
                                                                <MultiBinding Converter="{StaticResource VariableUsageTooltipConverter}">
                                                                    <Binding Path="Key" />
                                                                    <Binding Path="DataContext.VariableUsageVersion" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                </MultiBinding>
                                                            </TextBlock.ToolTip>
                                                        </TextBlock>
                                                        <Button Grid.Column="3" Content="X" Width="26" Height="24" Click="RemoveProjectVariableButton_Click" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Content="Add Variable" Width="110" Click="AddProjectVariableButton_Click" />
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="URLs">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Margin="0,0,0,8"
                                               Text="Define reusable base URLs and endpoint templates here. HTTP and GraphQL components can browse them and auto-fill their respective fields." />

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding ProjectUrlCatalogEntries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#E3E3E3" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8">
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="100" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Base Name" />
                                                                <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding Name, UpdateSourceTrigger=LostFocus}" />
                                                                <Button Grid.Column="2" Margin="0,0,6,0" Content="Add Endpoint" Width="95" Click="AddProjectUrlEndpointButton_Click" />
                                                                <Button Grid.Column="3" Content="Remove" Width="70" Click="RemoveProjectUrlBaseButton_Click" />
                                                            </Grid>
                                                            <Grid Margin="0,0,0,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="100" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Base URL" />
                                                                <TextBox Grid.Column="1" Text="{Binding BaseUrl, UpdateSourceTrigger=LostFocus}" />
                                                            </Grid>

                                                            <ItemsControl ItemsSource="{Binding Endpoints}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border BorderBrush="#D7D7D7" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8">
                                                                            <StackPanel>
                                                                                <Grid Margin="0,0,0,6">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="100" />
                                                                                        <ColumnDefinition Width="*" />
                                                                                        <ColumnDefinition Width="100" />
                                                                                        <ColumnDefinition Width="140" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Endpoint" />
                                                                                    <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding Name, UpdateSourceTrigger=LostFocus}" />
                                                                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Method" />
                                                                                    <ComboBox Grid.Column="3" Margin="0,0,6,0"
                                                                                              ItemsSource="{Binding DataContext.HttpMethodOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                              SelectedItem="{Binding Method, UpdateSourceTrigger=PropertyChanged}" />
                                                                                    <Button Grid.Column="4" Content="Remove" Width="70" Click="RemoveProjectUrlEndpointButton_Click" />
                                                                                </Grid>
                                                                                <Grid Margin="0,0,0,6">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="100" />
                                                                                        <ColumnDefinition Width="*" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Path" />
                                                                                    <TextBox Grid.Column="1" Text="{Binding Path, UpdateSourceTrigger=LostFocus}" />
                                                                                </Grid>
                                                                                <StackPanel Margin="0,0,0,6">
                                                                                    <Grid Margin="0,0,0,4">
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="100" />
                                                                                            <ColumnDefinition Width="*" />
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Parameters" />
                                                                                        <Button Grid.Column="1" HorizontalAlignment="Left" Content="+ Add Parameter" Width="110" Click="AddEndpointParameterButton_Click" />
                                                                                    </Grid>
                                                                                    <ItemsControl ItemsSource="{Binding Parameters}" Margin="100,0,0,0">
                                                                                        <ItemsControl.ItemTemplate>
                                                                                            <DataTemplate>
                                                                                                <Grid Margin="0,0,0,4">
                                                                                                    <Grid.ColumnDefinitions>
                                                                                                        <ColumnDefinition Width="*" />
                                                                                                        <ColumnDefinition Width="8" />
                                                                                                        <ColumnDefinition Width="*" />
                                                                                                        <ColumnDefinition Width="Auto" />
                                                                                                    </Grid.ColumnDefinitions>
                                                                                                    <TextBox Grid.Column="0" Text="{Binding Key, UpdateSourceTrigger=LostFocus}" ToolTip="Parameter key" />
                                                                                                    <TextBlock Grid.Column="1" Text="=" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                                                                    <TextBox Grid.Column="2" Margin="0,0,4,0" Text="{Binding Value, UpdateSourceTrigger=LostFocus}" ToolTip="Parameter value" />
                                                                                                    <Button Grid.Column="3" Content="×" Width="26" Click="RemoveEndpointParameterButton_Click" ToolTip="Remove" />
                                                                                                </Grid>
                                                                                            </DataTemplate>
                                                                                        </ItemsControl.ItemTemplate>
                                                                                    </ItemsControl>
                                                                                </StackPanel>
                                                                                <Grid Margin="0,0,0,6">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="100" />
                                                                                        <ColumnDefinition Width="*" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Top" Text="Headers" />
                                                                                    <TextBox Grid.Column="1" Height="60" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                                                                             Text="{Binding Headers, UpdateSourceTrigger=LostFocus}"
                                                                                             FontFamily="Consolas" FontSize="11"
                                                                                             ToolTip="HTTP headers as JSON object, e.g. {{&quot;Content-Type&quot;: &quot;application/json&quot;}}" />
                                                                                </Grid>
                                                                                <Grid Margin="0,0,0,6">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="100" />
                                                                                        <ColumnDefinition Width="*" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Top" Text="Body" />
                                                                                    <TextBox Grid.Column="1" Height="70" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding Body, UpdateSourceTrigger=LostFocus}" ToolTip="HTTP body or GraphQL query fallback." />
                                                                                </Grid>
                                                                                <Grid Margin="0,0,0,6">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="100" />
                                                                                        <ColumnDefinition Width="*" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Top" Text="GraphQL Query" />
                                                                                    <TextBox Grid.Column="1" Height="70" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding Query, UpdateSourceTrigger=LostFocus}" />
                                                                                </Grid>
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="100" />
                                                                                        <ColumnDefinition Width="*" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Top" Text="GraphQL Vars" />
                                                                                    <TextBox Grid.Column="1" Height="70" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding Variables, UpdateSourceTrigger=LostFocus}" />
                                                                                </Grid>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="Add Base URL" Width="110" Click="AddProjectUrlBaseButton_Click" />
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Preview">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock VerticalAlignment="Center" Text="Preview Data" Margin="0,0,8,0" />
                                        <ComboBox Width="140"
                                                  ItemsSource="{Binding PreviewDataModeOptions}"
                                                  SelectedItem="{Binding SelectedPreviewDataMode, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <TabControl Grid.Row="1">
                                        <TabItem Header="Flow JSON">
                                            <TextBox Text="{Binding JsonPreview}"
                                                     FontFamily="Consolas"
                                                     FontSize="12"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     HorizontalScrollBarVisibility="Auto"
                                                     IsReadOnly="True" />
                                        </TabItem>
                                        <TabItem Header="Variables">
                                            <TextBox Text="{Binding VariablesPreview}"
                                                     FontFamily="Consolas"
                                                     FontSize="12"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     HorizontalScrollBarVisibility="Auto"
                                                     IsReadOnly="True" />
                                        </TabItem>
                                        <TabItem Header="Logs">
                                            <TextBox Text="{Binding PreviewLogs}"
                                                     FontFamily="Consolas"
                                                     FontSize="12"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     HorizontalScrollBarVisibility="Auto"
                                                     IsReadOnly="True" />
                                        </TabItem>
                                        <TabItem Header="Assertions">
                                            <TextBox Text="{Binding AssertionPreview}"
                                                     FontFamily="Consolas"
                                                     FontSize="12"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     HorizontalScrollBarVisibility="Auto"
                                                     IsReadOnly="True" />
                                        </TabItem>
                                    </TabControl>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Border>

                    <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            VerticalAlignment="Stretch"
                            Visibility="{Binding IsComponentSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TabControl HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" VerticalAlignment="Stretch">
                                <TabItem Header="Properties">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="8">

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,6,0,8"
                            Visibility="{Binding IsHttpSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="HTTP" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Border Background="#F7F9FC" BorderBrush="#D8E2F0" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Fill From Project URLs" FontWeight="SemiBold" Foreground="#2F4F6F" />
                                    <TextBlock Margin="0,2,0,8"
                                               Foreground="#5F6F82"
                                               Text="Optional helper. Choose a saved base URL and endpoint, then apply it to the manual fields below." />
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Base URL" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding CatalogBaseUrlOptions}"
                                                  SelectedItem="{Binding SelectedHttpCatalogBase, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
