                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Output Variable" />
                                <TextBox Grid.Column="1" Text="{Binding ForeachOutputVariable, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Optional variable name that stores the current item for use by child components (defaults to CurrentItem)." />
                            </Grid>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
