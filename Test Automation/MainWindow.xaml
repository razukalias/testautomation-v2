                                    <RowDefinition x:Name="AssertionTreeAreaRow" Height="*" MinHeight="120" />
                                </Grid.RowDefinitions>

                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SelectedNode.Assertions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="90" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox Grid.Column="0"
                                                              Margin="0,0,6,0"
                                                              ItemsSource="{Binding DataContext.AssertionModeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedItem="{Binding Mode, UpdateSourceTrigger=PropertyChanged}" />
                                                    <ComboBox Grid.Column="1"
                                                              Margin="0,0,6,0"
                                                              ItemsSource="{Binding DataContext.ExtractorSourceOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              Text="{Binding Source, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBox Grid.Column="2" Margin="0,0,6,0" Text="{Binding JsonPath, UpdateSourceTrigger=PropertyChanged}" />
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,6,0">
                                                        <Button Width="32"
                                                                Height="24"
                                                                Margin="0,0,4,0"
                                                                Content="..."
                                                                ToolTip="Explore JSON paths"
                                                                Click="ExploreJsonPathButton_Click" />
                                                        <Button Width="40"
                                                                Height="24"
                                                                Content="Tree"
                                                                ToolTip="Pick JSON node for assertion expected value"
                                                                Click="ExploreAssertionExpectedJsonButton_Click" />
                                                    </StackPanel>
                                                    <ComboBox Grid.Column="4"
                                                              Margin="0,0,6,0"
                                                              ItemsSource="{Binding DataContext.AssertionConditionOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedItem="{Binding Condition, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBox Grid.Column="5"
                                                             Margin="0,0,6,0"
                                                             Text="{Binding Expected, UpdateSourceTrigger=PropertyChanged}"
                                                             PreviewMouseLeftButtonDown="AssertionExpectedTextBox_PreviewMouseLeftButtonDown">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="AcceptsReturn" Value="False" />
                                                                <Setter Property="TextWrapping" Value="NoWrap" />
                                                                <Setter Property="Height" Value="24" />
                                                                <Setter Property="MinHeight" Value="24" />
                                                                <Setter Property="MaxHeight" Value="24" />
                                                                <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
                                                                <Setter Property="HorizontalScrollBarVisibility" Value="Hidden" />
                                                                <Setter Property="IsReadOnly" Value="True" />
                                                                <Setter Property="Cursor" Value="Hand" />
                                                                <Setter Property="ToolTip" Value="Click to open expected value editor" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Condition}" Value="Script">
                                                                        <Setter Property="ToolTip" Value="Click to open script editor" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                    <Border Grid.Column="6" Margin="0,0,6,0" CornerRadius="3" Padding="6,2" BorderBrush="#D1D5DB" BorderThickness="1">
                                                        <TextBlock Text="{Binding StatusLabel}" ToolTip="{Binding StatusMessage}" HorizontalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#6B7280" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding LastResultState}" Value="Passed">
                                                                            <Setter Property="Foreground" Value="#166534" />
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding LastResultState}" Value="AssertFailed">
                                                                            <Setter Property="Foreground" Value="#B00020" />
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding LastResultState}" Value="ExpectFailed">
                                                                            <Setter Property="Foreground" Value="#A16207" />
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <Button Grid.Column="7" Content="X" Width="26" Height="24" Click="RemoveAssertionButton_Click" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <GridSplitter Grid.Row="1"
                                              Height="6"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              Background="#E0E0E0"
                                              ResizeDirection="Rows"
                                              ResizeBehavior="PreviousAndNext"
                                              ShowsPreview="True" />

                                <Border Grid.Row="2" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,8,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" MinHeight="80" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="AssertionTreeLeftColumn" Width="2*" MinWidth="160" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition x:Name="AssertionTreeRightColumn" Width="3*" MinWidth="220" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="Assertion Tree" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <TextBlock Text="Source" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <ComboBox x:Name="AssertionTreeSourceComboBox"
                                                  Width="180"
                                                  Margin="0,0,6,0"
                                                  ItemsSource="{Binding ExtractorSourceOptions}"
                                                  SelectionChanged="AssertionTreeSourceComboBox_SelectionChanged" />
                                        <Button Width="70" Content="Refresh" Click="RefreshAssertionTreeButton_Click" />
                                    </StackPanel>

                                    <TreeView x:Name="AssertionJsonTreeView"
                                              Grid.Row="1"
                                              Grid.Column="0"
                                              Margin="0,0,8,0"
                                              SelectedItemChanged="AssertionJsonTreeView_SelectedItemChanged">
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                    </TreeView>

                                     <GridSplitter Grid.Row="1"
                                                Grid.Column="1"
                                                Width="6"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                Background="#E0E0E0"
                                                ResizeDirection="Columns"
                                                ResizeBehavior="PreviousAndNext"
                                                ShowsPreview="True" />

                                    <TextBox x:Name="AssertionTreeValuePreviewTextBox"
                                             Grid.Row="1"
                                            Grid.Column="2"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             Text="Select a tree node to preview value." />

                                    <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AssertionTreeSelectedPathTextBlock"
                                                   Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"
