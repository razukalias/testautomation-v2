                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Count" />
                                <TextBox Grid.Column="1" Text="{Binding ThreadCount, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="RampUp (s)" />
                                <TextBox Grid.Column="1" Text="{Binding RampUpSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsAssertSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Assert" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Expected" />
                                <TextBox Grid.Column="1" Text="{Binding AssertExpected, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Actual" />
                                <TextBox Grid.Column="1" Text="{Binding AssertActual, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsVariableExtractorSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Variable Extractor" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Pattern" />
                                <TextBox Grid.Column="1" Text="{Binding ExtractorPattern, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Variable" />
                                <TextBox Grid.Column="1" Text="{Binding ExtractorVariableName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="#666666">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource VariableUsageLabelConverter}">
                                            <Binding Path="ExtractorVariableName" />
                                            <Binding Path="VariableUsageVersion" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                    <TextBlock.ToolTip>
                                        <MultiBinding Converter="{StaticResource VariableUsageTooltipConverter}">
                                            <Binding Path="ExtractorVariableName" />
                                            <Binding Path="VariableUsageVersion" />
                                        </MultiBinding>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsScriptSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Script" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Language" />
                                <TextBox Grid.Column="1" Text="{Binding ScriptLanguage, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Top" Text="Code" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding ScriptCode, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         Height="80"
                                         VerticalScrollBarVisibility="Auto"
                                         IsReadOnly="True"
                                         Cursor="Hand"
                                         ToolTip="Click to open script editor"
                                         PreviewMouseLeftButtonDown="ScriptCodeTextBox_PreviewMouseLeftButtonDown" />
                            </Grid>
                        </StackPanel>
                    </Border>

                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem Header="Extract Variables">
                    <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Extract Variables" FontWeight="SemiBold" Margin="0,0,0,6" />

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Source Field" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="JSON Path" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="3" Text="Variable Name" FontWeight="SemiBold" />
                            </Grid>

                            <ScrollViewer MinHeight="120" VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch">
                                <ItemsControl ItemsSource="{Binding SelectedNode.Extractors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0"
                                                          Margin="0,0,6,0"
                                                          ItemsSource="{Binding DataContext.ExtractorSourceOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          Text="{Binding Source, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding JsonPath, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Grid.Column="2"
                                                        Margin="0,0,6,0"
                                                        Width="32"
                                                        Height="24"
                                                        Content="..."
                                                        ToolTip="Explore JSON paths"
                                                        Click="ExploreJsonPathButton_Click" />
                                                <Grid Grid.Column="3" Margin="0,0,6,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0" Margin="0,0,6,0" Text="{Binding VariableName, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="#666666">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource VariableUsageLabelConverter}">
                                                                <Binding Path="VariableName" />
                                                                <Binding Path="DataContext.VariableUsageVersion" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                        <TextBlock.ToolTip>
                                                            <MultiBinding Converter="{StaticResource VariableUsageTooltipConverter}">
                                                                <Binding Path="VariableName" />
                                                                <Binding Path="DataContext.VariableUsageVersion" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                            </MultiBinding>
                                                        </TextBlock.ToolTip>
                                                    </TextBlock>
                                                </Grid>
                                                <Button Grid.Column="4" Content="X" Width="26" Height="24" Click="RemoveExtractorButton_Click" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="Add Extractor" Width="120" Click="AddExtractorButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                                </TabItem>

                            <TabItem Header="Assertions">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Assertions" FontWeight="SemiBold" Margin="0,0,0,6" />

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Mode" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Source" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="JSON Path" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="4" Text="Condition" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="5" Text="Expected" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="6" Text="Status" FontWeight="SemiBold" />
                            </Grid>

                            <Grid MinHeight="260" Margin="0,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition x:Name="AssertionRowsAreaRow" Height="120" MinHeight="70" />
