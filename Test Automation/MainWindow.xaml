                                                   TextTrimming="CharacterEllipsis"
                                                   Text="Path: (none)" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Width="130"
                                                    Margin="0,0,6,0"
                                                    Content="Add Selected Row"
                                                    Click="AddSelectedTreeNodeAssertionButton_Click" />
                                            <Button Width="190"
                                                    Content="Generate Rows For Tree"
                                                    Click="GenerateTreeAssertionsButton_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>
                        </ScrollViewer>
                                </TabItem>

