<Window x:Class="Test_Automation.AssertionViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test_Automation"
        mc:Ignorable="d"
        Title="Assertion History"
        Height="600" Width="950"
        MinHeight="480" MinWidth="750"
        WindowStartupLocation="CenterOwner"
        >
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Preview Mode + Filter Controls -->
        <Border Grid.Row="0"  BorderThickness="1" 
                CornerRadius="4" Padding="10" Margin="0,0,0,10" >
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Preview Mode:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <ComboBox x:Name="PreviewModeComboBox" Width="130" Margin="0,0,25,0"
                          VerticalAlignment="Center"/>
                <Separator Width="1" Margin="0,0,15,0" />
                <TextBlock Text="Filter:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <RadioButton x:Name="ShowAllRadio" Content="Show All" 
                             VerticalAlignment="Center" Margin="0,0,15,0" 
                             IsChecked="True" Checked="FilterRadio_Changed"/>
                <RadioButton x:Name="FailedOnlyRadio" Content="Failed Only" 
                             VerticalAlignment="Center" Margin="0,0,15,0"
                             Checked="FilterRadio_Changed"/>
                <Separator Width="1" Margin="0,0,15,0" />
                <TextBlock x:Name="SummaryTextBlock" VerticalAlignment="Center" 
                           />
            </StackPanel>
        </Border>

        <!-- Row 1: Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Component List -->
            <Border Grid.Column="0"  BorderThickness="1" 
                    CornerRadius="4" Padding="8" Margin="0,0,8,0" >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Components with Assertions" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    
                    <!-- TreeView for hierarchical display -->
                    <TreeView x:Name="ComponentsTreeView" Grid.Row="1" 
                              BorderThickness="1" 
                              SelectedItemChanged="ComponentsTreeView_SelectedItemChanged"
                              Visibility="Collapsed">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="Margin" Value="0,0,0,1"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                    
                    <!-- ListBox for simple display -->
                    <ListBox x:Name="ComponentsListBox" Grid.Row="1" 
                             BorderThickness="1" 
                             SelectionChanged="ComponentsListBox_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="Margin" Value="0,0,0,2"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Status icon and name -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                                                Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="{Binding StatusIcon}" 
                                                   Foreground="{Binding StatusIconBrush}" 
                                                   FontWeight="Bold" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding ComponentName}" 
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    
                                    <!-- Assertion counts -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                                                Orientation="Horizontal" Margin="20,0,0,0">
                                        <TextBlock FontSize="11" >
                                            <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                                            <Run Text=" assertions"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Margin="8,0,0,0">
                                            <Run Text="(" />
                                            <Run Text="{Binding PassedCount, Mode=OneWay}" Foreground="#166534"/>
                                            <Run Text="/" />
                                            <Run Text="{Binding FailedCount, Mode=OneWay}" Foreground="#B00020"/>
                                            <Run Text=" failed)" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6"  
                          Margin="0,0,8,0"/>

            <!-- Right Panel: Bar Chart + Assertion List -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Bar Chart Area -->
                <Border Grid.Row="0"  BorderThickness="1" 
                        CornerRadius="4" Padding="12" Margin="0,0,0,8" >
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Assertion Status by Step" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        
                        <!-- Legend -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,-4,0,0">
                            <Rectangle Width="12" Height="12" Fill="#166534" RadiusX="2" RadiusY="2" Margin="0,0,4,0"/>
                            <TextBlock Text="Passed" FontSize="11" Margin="0,0,12,0"/>
                            <Rectangle Width="12" Height="12" Fill="#B00020" RadiusX="2" RadiusY="2" Margin="0,0,4,0"/>
                            <TextBlock Text="Failed" FontSize="11"/>
                        </StackPanel>
                        
                        <!-- Chart container -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Disabled" 
                                      HorizontalScrollBarVisibility="Auto" Margin="0,8,0,0">
                            <ItemsControl x:Name="BarChartItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="8,0" HorizontalAlignment="Center" Width="90">
                                            <!-- TestPlan Header label -->
                                            <TextBlock Text="{Binding StepLabel}" 
                                                       HorizontalAlignment="Center" 
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="80" Margin="0,0,0,4"
                                                       >
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                        <Setter Property="FontSize" Value="10"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTestPlanHeader}" Value="True">
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                <Setter Property="FontSize" Value="12"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            
                                            <!-- Bar (only for non-header items) -->
                                            <Grid Height="80" Margin="0,0,0,4">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTestPlanHeader}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <!-- Failed portion (top) -->
                                                <Border VerticalAlignment="Top" 
                                                        Height="{Binding FailedHeight}"
                                                        Background="#B00020" 
                                                        CornerRadius="3,3,0,0"
                                                        MinHeight="0"/>
                                                <!-- Passed portion (bottom) -->
                                                <Border VerticalAlignment="Bottom" 
                                                        Height="{Binding PassedHeight}"
                                                        Background="#166534"
                                                        CornerRadius="0,0,3,3"
                                                        MinHeight="0"/>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Assertion List Header -->
                <Border Grid.Row="1"  
                         BorderThickness="1,1,1,0"
                        CornerRadius="4,4,0,0" Padding="10,8" Margin="0,0,0,0">
                    <TextBlock x:Name="AssertionListTitle" Text="Assertions" FontWeight="SemiBold"/>
                </Border>

                <!-- Assertion Details DataGrid -->
                <Border Grid.Row="2"  BorderThickness="1,0,1,1" 
                        CornerRadius="0,0,4,4" Margin="0,0,0,0">
                    <DataGrid x:Name="AssertionsDataGrid" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              
                              CanUserSortColumns="True"
                              BorderThickness="0"
                              >
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="TestPlan" Binding="{Binding TestPlanName}" Width="100"/>
                            <DataGridTextColumn Header="Component" Binding="{Binding ComponentName}" Width="120"/>
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="80"/>
                            <DataGridTextColumn Header="Condition" Binding="{Binding Condition}" Width="80"/>
                            <DataGridTextColumn Header="Expected" Binding="{Binding Expected}" Width="*"/>
                            <DataGridTextColumn Header="Actual" Binding="{Binding Actual}" Width="*"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
