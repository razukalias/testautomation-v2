<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme Colors (Deep Space / Elegant) -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#18181B"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#27272A"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#3F3F46"/>
    <SolidColorBrush x:Key="SurfaceSelectedBrush" Color="#2D3A5D"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="#3B82F6"/>
    
    <SolidColorBrush x:Key="PrimaryBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="SecondaryBrush" Color="#3F3F46"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#52525B"/>
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="#F8FAFC"/>

    <SolidColorBrush x:Key="TextBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#A1A1AA"/>

    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
</ResourceDictionary>
