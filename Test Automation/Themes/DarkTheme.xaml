<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme Colors (Tailwind inspired) -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#111827"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#374151"/>
    <SolidColorBrush x:Key="SurfaceSelectedBrush" Color="#1E3A8A"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#374151"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="#60A5FA"/>
    
    <SolidColorBrush x:Key="PrimaryBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="SecondaryBrush" Color="#374151"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#4B5563"/>
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="#F9FAFB"/>

    <SolidColorBrush x:Key="TextBrush" Color="#F9FAFB"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#9CA3AF"/>

    <SolidColorBrush x:Key="ErrorBrush" Color="#F87171"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#34D399"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FBBF24"/>
</ResourceDictionary>
