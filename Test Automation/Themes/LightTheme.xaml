<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Light Theme Colors (Clean / Elegant) -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="SurfaceSelectedBrush" Color="#E0F2FE"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="#3B82F6"/>
    
    <SolidColorBrush x:Key="PrimaryBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="SecondaryBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="#0F172A"/>

    <SolidColorBrush x:Key="TextBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B"/>

    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
</ResourceDictionary>
